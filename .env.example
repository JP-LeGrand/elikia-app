# Email transport: set RESEND_API_KEY to use Resend (recommended for Netlify/cloud),
# or configure SMTP_* variables to use direct SMTP.

# --- Resend (recommended for Netlify deployments) ---
# Sign up at https://resend.com, verify your domain, and create an API key.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- SMTP (works when the server has direct network access to the mail host) ---
# For one.com: use mailout.one.com when sending from a web server (not send.one.com, which is for email clients)
SMTP_HOST=mailout.one.com
SMTP_PORT=587
SMTP_USER=contact@elikia-cf.com
SMTP_PASSWORD=change_this_password

# --- Shared (used by both transports) ---
CONTACT_TO_EMAIL=contact@elikia-cf.com
CONTACT_FROM_EMAIL=contact@elikia-cf.com
CONTACT_SUBJECT_PREFIX=Website Contact
