# one.com SMTP settings for sending email from the website contact form.
# IMPORTANT: Use "mailout.one.com" (for web servers), NOT "send.one.com" (for email clients).
# See: https://help.one.com/hc/en-us/articles/115005594345
SMTP_HOST=mailout.one.com
# Recommended: 587 (STARTTLS). Also supported: 465 (SSL/TLS), 25 (STARTTLS/none).
SMTP_PORT=587
# Must be an active email account on your one.com domain.
SMTP_USER=contact@elikia-cf.com
SMTP_PASSWORD=change_this_password

CONTACT_TO_EMAIL=contact@elikia-cf.com
CONTACT_FROM_EMAIL=contact@elikia-cf.com
CONTACT_SUBJECT_PREFIX=Website Contact
